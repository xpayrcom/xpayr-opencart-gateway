{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-payment" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_status" id="input-status" class="form-control">
                {% if payment_xpayr_status %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_xpayr_title" value="{{ payment_xpayr_title }}" placeholder="{{ entry_title }}" id="input-title" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-description">{{ entry_description }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_xpayr_description" value="{{ payment_xpayr_description }}" placeholder="{{ entry_description }}" id="input-description" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-api-base-url"><span data-toggle="tooltip" title="{{ help_api_base_url }}">{{ entry_api_base_url }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_xpayr_api_base_url" value="{{ payment_xpayr_api_base_url }}" placeholder="{{ entry_api_base_url }}" id="input-api-base-url" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-secret-key"><span data-toggle="tooltip" title="{{ help_secret_key }}">{{ entry_secret_key }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_xpayr_secret_key" value="{{ payment_xpayr_secret_key }}" placeholder="{{ entry_secret_key }}" id="input-secret-key" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-network">{{ entry_network }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_network" id="input-network" class="form-control">
                {% for network in network_options %}
                  {% if network.key == payment_xpayr_network %}
                    <option value="{{ network.key }}" selected="selected">{{ network.name }}</option>
                  {% else %}
                    <option value="{{ network.key }}">{{ network.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-currency">{{ entry_currency }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_currency" id="input-currency" class="form-control">
                {% for currency in currency_options %}
                  {% if currency.key == payment_xpayr_currency %}
                    <option value="{{ currency.key }}" selected="selected">{{ currency.name }}</option>
                  {% else %}
                    <option value="{{ currency.key }}">{{ currency.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-webhook-auto-sync"><span data-toggle="tooltip" title="{{ help_webhook_auto_sync }}">{{ entry_webhook_auto_sync }}</span></label>
            <div class="col-sm-10">
              <select name="payment_xpayr_webhook_auto_sync" id="input-webhook-auto-sync" class="form-control">
                {% if payment_xpayr_webhook_auto_sync %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
              <p class="help-block"><strong>{{ help_webhook_url }}:</strong> {{ webhook_url }}</p>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-webhook-secret"><span data-toggle="tooltip" title="{{ help_webhook_secret }}">{{ entry_webhook_secret }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_xpayr_webhook_secret" value="{{ payment_xpayr_webhook_secret }}" placeholder="{{ entry_webhook_secret }}" id="input-webhook-secret" class="form-control" />
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-pending-status">{{ entry_pending_status }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_pending_status_id" id="input-pending-status" class="form-control">
                {% for order_status in order_statuses %}
                  {% if order_status.order_status_id == payment_xpayr_pending_status_id %}
                    <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                  {% else %}
                    <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-paid-status">{{ entry_paid_status }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_paid_status_id" id="input-paid-status" class="form-control">
                {% for order_status in order_statuses %}
                  {% if order_status.order_status_id == payment_xpayr_paid_status_id %}
                    <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                  {% else %}
                    <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-failed-status">{{ entry_failed_status }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_failed_status_id" id="input-failed-status" class="form-control">
                {% for order_status in order_statuses %}
                  {% if order_status.order_status_id == payment_xpayr_failed_status_id %}
                    <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                  {% else %}
                    <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-expired-status">{{ entry_expired_status }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_expired_status_id" id="input-expired-status" class="form-control">
                {% for order_status in order_statuses %}
                  {% if order_status.order_status_id == payment_xpayr_expired_status_id %}
                    <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                  {% else %}
                    <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                  {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-debug">{{ entry_debug }}</label>
            <div class="col-sm-10">
              <select name="payment_xpayr_debug" id="input-debug" class="form-control">
                {% if payment_xpayr_debug %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_xpayr_sort_order" value="{{ payment_xpayr_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
